{
  "name": "boatconnect",
  "version": "0.1.0",
  "description": "Multi-transport binary frame codec and fleet session multiplexer for dragon boat telemetry",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --experimental-strip-types --test test/*.test.ts",
    "example:encode": "bun examples/encode-sample.ts",
    "example:udp-listen": "bun examples/udp-listen.ts",
    "example:ws-bun": "bun examples/ws-bun-server.ts",
    "example:tcp-server": "bun examples/tcp-server.ts",
    "example:udp-send": "bun examples/udp-send.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["dragon-boat", "telemetry", "binary", "esp32"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
